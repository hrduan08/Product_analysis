// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum Platform {
  youtube
  reddit
}

enum SubscriptionFrequency {
  instant
  daily
  weekly
}

enum JobStatus {
  success
  failed
  partial
}

enum AlertSeverity {
  info
  warning
  critical
}

enum UserStatus {
  trialing
  active
  past_due
  canceled
}

enum BillingInterval {
  monthly
  yearly
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired
}

enum InvoiceStatus {
  pending
  paid
  failed
  refunded
}

enum PaymentProvider {
  wechat
  alipay
  wechat_personal
  mock
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
  canceled
  expired
}

model FeedbackItem {
  id            String    @id @default(uuid()) @db.Uuid
  platform      Platform
  external_id   String
  keyword       String
  title         String
  author        String?
  url           String
  thumbnail_url String?
  permalink     String?
  published_at  DateTime? @db.Timestamptz(6)
  first_seen_at DateTime  @default(now()) @db.Timestamptz(6)
  last_seen_at  DateTime? @db.Timestamptz(6)
  view_count    Int?
  score         Int?
  comment_count Int?
  metadata      Json?     @db.JsonB
  userFeedbackItems UserFeedbackItem[]

  @@unique([platform, external_id])
  @@index([keyword, last_seen_at(sort: Desc)])
  @@index([first_seen_at(sort: Desc)])
  @@map("feedback_items")
}

model Subscription {
  id             String                 @id @default(uuid()) @db.Uuid
  email          String                 @unique
  keywords       String[]               @default([])
  platforms      Platform[]             @default([youtube, reddit])
  frequency      SubscriptionFrequency  @default(daily)
  last_notified  DateTime?              @db.Timestamptz(6)

  @@map("subscriptions")
}

model NotifyJob {
  id            String    @id @default(uuid()) @db.Uuid
  run_at        DateTime  @default(now()) @db.Timestamptz(6)
  process_status JobStatus?
  notify_status  JobStatus?
  total_new     Int       @default(0)
  total_sent    Int       @default(0)
  error_message String?
  mail_message_id String?
  user_id       String?   @db.Uuid
  context       Json?     @db.JsonB

  user User? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([run_at(sort: Desc)])
  @@index([user_id, run_at(sort: Desc)])
  @@map("notify_jobs")
}

model Alert {
  id               String         @id @default(uuid()) @db.Uuid
  dedupe_key       String         @unique
  message          String
  severity         AlertSeverity  @default(warning)
  tags             String[]       @default([])
  occurrences      Int            @default(1)
  last_triggered_at DateTime      @default(now()) @db.Timestamptz(6)
  last_notified_at DateTime?      @db.Timestamptz(6)
  payload          Json?          @db.JsonB
  source           String?
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @updatedAt @db.Timestamptz(6)

  @@index([last_triggered_at(sort: Desc)])
  @@map("alerts")
}

model YoutubeQuotaUsage {
  id           String   @id @default(uuid()) @db.Uuid
  api_key      String
  usage_date   DateTime @db.Date
  search_calls Int      @default(0)
  video_calls  Int      @default(0)
  units_used   Int      @default(0)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @updatedAt @db.Timestamptz(6)

  @@unique([api_key, usage_date])
  @@map("youtube_quota_usage")
}

model FeedbackReport {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String?  @db.Uuid
  anonymous_id   String?
  category       String
  title          String
  description    String
  attachments    Json?    @db.JsonB
  diagnostics    Json?    @db.JsonB
  contact_email  String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @updatedAt @db.Timestamptz(6)

  user  User?           @relation(fields: [user_id], references: [id], onDelete: SetNull)
  notes FeedbackNote[]

  @@index([created_at(sort: Desc)])
  @@map("feedback_reports")
}

model FeedbackNote {
  id         String   @id @default(uuid()) @db.Uuid
  report_id  String   @db.Uuid
  content    String
  created_by String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  report FeedbackReport @relation(fields: [report_id], references: [id], onDelete: Cascade)

  @@map("feedback_notes")
}

model User {
  id               String      @id @default(uuid()) @db.Uuid
  email            String      @unique
  password_hash    String
  email_verified_at DateTime?  @db.Timestamptz(6)
  status           UserStatus  @default(trialing)
  trial_started_at DateTime    @default(now()) @db.Timestamptz(6)
  trial_ends_at    DateTime    @db.Timestamptz(6)
  plan_id          String?     @db.Uuid
  plan_expire_at   DateTime?   @db.Timestamptz(6)
  trial_reminder_sent_at DateTime? @db.Timestamptz(6)
  role             String      @default("user")
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime    @updatedAt @db.Timestamptz(6)

  profile        UserProfile?
  refreshTokens  RefreshToken[]
  plan           Plan?         @relation(fields: [plan_id], references: [id])
  subscriptions  UserSubscription[]
  invoices       Invoice[]
  paymentOrders  PaymentOrder[]
  notifyJobs     NotifyJob[]
  searchConfig   UserSearchConfig?
  feedbackReports FeedbackReport[]
  userFeedbackItems UserFeedbackItem[]

  @@map("users")
}

model UserProfile {
  user_id  String   @id @db.Uuid
  full_name String?
  timezone String?  @default("Asia/Shanghai")
  locale   String?  @default("zh-CN")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserSearchConfig {
  user_id         String    @id @db.Uuid
  platforms       String[]  @default(["youtube", "reddit"])
  reddit_communities String[] @default([])
  reddit_keywords  String[]  @default([])
  youtube_keywords String[]  @default([])
  product_website_url String?
  product_commerce_url String?
  product_description String?
  product_profile_status String? @default("idle")
  product_profile_error String?
  product_profile_generated_at DateTime? @db.Timestamptz(6)
  product_profile_updated_by_user Boolean @default(false)
  product_profile_brand String?
  product_profile_product_name String?
  product_profile_category String?
  product_profile_core_features String[] @default([])
  product_profile_competitors String[] @default([])
  notify_email    String
  timezone        String    @default("Asia/Shanghai")
  notify_channels String[]  @default(["feishu"])
  feishu_webhook  String?
  feishu_status   String?
  feishu_last_tested_at DateTime? @db.Timestamptz(6)
  next_run_at     DateTime? @db.Timestamptz(6)
  reddit_last_run_at DateTime? @db.Timestamptz(6)
  youtube_last_run_at DateTime? @db.Timestamptz(6)
  last_notified_at DateTime? @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_search_configs")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  token_hash String   @unique
  user_id    String   @db.Uuid
  expires_at DateTime @db.Timestamptz(6)
  revoked    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@map("refresh_tokens")
}

model Plan {
  id               String           @id @default(uuid()) @db.Uuid
  code             String           @unique
  name             String
  description      String?
  price_cents      Int
  currency         String           @default("CNY")
  billing_interval BillingInterval  @default(monthly)
  is_active        Boolean          @default(true)
  limits           Json?            @db.JsonB
  metadata         Json?            @db.JsonB
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime         @updatedAt @db.Timestamptz(6)

  users            User[]
  subscriptions    UserSubscription[]
  invoices         Invoice[]
  paymentOrders    PaymentOrder[]

  @@map("plans")
}

model UserSubscription {
  id                    String             @id @default(uuid()) @db.Uuid
  user_id               String             @db.Uuid
  plan_id               String             @db.Uuid
  status                SubscriptionStatus
  started_at            DateTime           @default(now()) @db.Timestamptz(6)
  current_period_start  DateTime           @default(now()) @db.Timestamptz(6)
  current_period_end    DateTime           @db.Timestamptz(6)
  cancel_at_period_end  Boolean            @default(false)
  canceled_at           DateTime?          @db.Timestamptz(6)
  trial_ends_at         DateTime?          @db.Timestamptz(6)
  renewal_reminder_sent_at DateTime?       @db.Timestamptz(6)
  created_at            DateTime           @default(now()) @db.Timestamptz(6)
  updated_at            DateTime           @updatedAt @db.Timestamptz(6)

  user                  User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan                  Plan               @relation(fields: [plan_id], references: [id])
  invoices              Invoice[]
  paymentOrders         PaymentOrder[]

  @@index([user_id, status])
  @@index([plan_id])
  @@index([current_period_end])
  @@map("user_subscriptions")
}

model Invoice {
  id               String        @id @default(uuid()) @db.Uuid
  subscription_id  String?       @db.Uuid
  user_id          String        @db.Uuid
  plan_id          String?       @db.Uuid
  payment_order_id String?       @unique @db.Uuid
  amount_cents     Int
  currency         String        @default("CNY")
  status           InvoiceStatus @default(pending)
  external_id      String?
  external_data    Json?         @db.JsonB
  description      String?
  issued_at        DateTime      @default(now()) @db.Timestamptz(6)
  due_at           DateTime?     @db.Timestamptz(6)
  paid_at          DateTime?     @db.Timestamptz(6)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @updatedAt @db.Timestamptz(6)

  subscription     UserSubscription? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan             Plan?             @relation(fields: [plan_id], references: [id])
  paymentOrder     PaymentOrder?     @relation("PaymentOrderInvoice", fields: [payment_order_id], references: [id])

  @@index([user_id])
  @@index([subscription_id])
  @@index([payment_order_id])
  @@index([status])
  @@map("invoices")
}

model PaymentOrder {
  id               String        @id @default(uuid()) @db.Uuid
  user_id          String        @db.Uuid
  plan_id          String        @db.Uuid
  subscription_id  String?       @db.Uuid
  provider         PaymentProvider
  status           PaymentStatus @default(pending)
  amount_cents     Int
  currency         String        @default("CNY")
  description      String?
  out_trade_no     String        @unique
  external_trade_no String?
  external_payload Json?         @db.JsonB
  notify_payload   Json?         @db.JsonB
  last_error       String?
  retry_count      Int           @default(0)
  expires_at       DateTime?
  paid_at          DateTime?
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @updatedAt @db.Timestamptz(6)

  user          User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan          Plan              @relation(fields: [plan_id], references: [id])
  subscription  UserSubscription? @relation(fields: [subscription_id], references: [id], onDelete: SetNull)
  invoice       Invoice?          @relation("PaymentOrderInvoice")

  @@index([user_id, status])
  @@index([subscription_id])
  @@index([plan_id])
  @@map("payment_orders")
}

/// 记录每个用户首次/最近看到的抓取内容，用于用户级去重与增量
model UserFeedbackItem {
  user_id          String   @db.Uuid
  feedback_item_id String   @db.Uuid
  matched_keywords String[] @default([])
  first_seen_at    DateTime @default(now()) @db.Timestamptz(6)
  last_seen_at     DateTime @default(now()) @db.Timestamptz(6)
  last_notified_at DateTime? @db.Timestamptz(6)
  profile_filter_status String? @default("pending")
  profile_filter_score  Float?
  profile_filter_reason String?
  profile_filtered_at   DateTime? @db.Timestamptz(6)

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  feedbackItem FeedbackItem @relation(fields: [feedback_item_id], references: [id], onDelete: Cascade)

  @@id([user_id, feedback_item_id])
  @@index([feedback_item_id])
  @@index([last_seen_at])
  @@map("user_feedback_items")
}
