{
  "name": "@app/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:agent": "tsx watch src/agent.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "build:agent": "tsup src/agent.ts --format esm --out-dir dist-agent --clean",
    "start": "node dist/index.js",
    "start:agent": "node dist-agent/agent.js",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "seed:plans": "tsx scripts/seed-plans.ts",
    "report:payments": "tsx scripts/list-payment-orders.ts",
    "retry:payment": "tsx scripts/retry-payment-order.ts",
    "expire:payments": "tsx scripts/expire-payment-orders.ts",
    "scan:payments": "tsx scripts/scan-payment-anomalies.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@supabase/supabase-js": "^2.46.1",
    "alipay-sdk": "^3.6.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "uuid": "^11.0.2",
    "undici": "^7.3.0",
    "wechatpay-node-v3": "^2.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.8.7",
    "@types/nodemailer": "^7.0.3",
    "nock": "^14.0.4",
    "prisma": "^6.18.0",
    "supertest": "^6.3.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^1.3.1"
  }
}
